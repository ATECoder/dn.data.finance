{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "*.{css,scss,js,png,gif,ico,jpg,jpeg,svg,wasm,json}",
      "/api/*"
    ]
  },
  "mimeTypes": {
    ".wasm": "application/wasm",
    ".json": "application/json"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "trailingSlash": "auto"
}
