<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="cc.isr.Finance.Sep.Ira.Views.AppreciatorPage"
             Title="SEP IRA Calculator"
             Padding="10"
             WidthRequest="600">

  <Grid RowDefinitions="Auto,*,Auto,Auto" ColumnDefinitions="*" ColumnSpacing="10" RowSpacing="10"
          WidthRequest="600"
          HorizontalOptions="Center">

        <!-- Title and Instructions -->
        <VerticalStackLayout Padding="10" Grid.Row="0" Spacing="5">
            <Label Text="SEP-IRA Appreciation Calculator"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Calculate Simple Investment vs. SEP IRA Comparison"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Error Message Display -->
        <Border x:Name="ErrorFrame"
                Grid.Row="0"
                Stroke="#FF4444"
                StrokeShape="RoundRectangle 8"
                Padding="15"
                Margin="0,60,0,0"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyBoolConverter}}">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#FF4444"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap" />
        </Border>

        <!-- Scrollable Input Form -->
        <ScrollView Grid.Row="1" Margin="0,10,0,0">
            <VerticalStackLayout Padding="5" Spacing="10">

                <!-- Row 1: Invested Amount -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Invested Amount ($)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding InvestedAmount}"
                           Placeholder="10000"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 2: Initial Age -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Initial Age"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding InitialAge}"
                           Placeholder="75"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 3: Investment Duration -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Investment Duration (years)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding InvestmentDuration}"
                           Placeholder="20"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 4: Initial Federal Tax Rate -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Initial Federal Tax Rate (%)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding InitialFederalTaxRate}"
                           Placeholder="35.0"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 5: Withdrawal Federal Tax Rate -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Withdrawal Federal Tax Rate (%)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding WithdrawalFederalTaxRate}"
                           Placeholder="35.0"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 6: Initial State Tax Rate -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Initial State Tax Rate (%)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding InitialStateTaxRate}"
                           Placeholder="9.3"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 7: Withdrawal State Tax Rate -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Withdrawal State Tax Rate (%)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding WithdrawalStateTaxRate}"
                           Placeholder="9.3"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 8: Federal Capital Gains Tax Rate -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Federal Capital Gains Tax Rate (%)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding FederalCapitalGainsTaxRate}"
                           Placeholder="25.0"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 9: State Capital Gains Tax Rate -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="State Capital Gains Tax Rate (%)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding StateCapitalGainsTaxRate}"
                           Placeholder="9.3"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 10: Annual Inflation Rate -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Annual Inflation Rate (%)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding AnnualInflationRate}"
                           Placeholder="2.75"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Row 11: Annual Growth Rate -->
                <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                    <Label Text="Annual Growth Rate (%)"
                           VerticalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1"
                           Text="{Binding AnnualGrowthRate}"
                           Placeholder="7.0"
                           Keyboard="Numeric"
                           FontSize="14" />
                </Grid>

                <!-- Spacer -->
                <BoxView HeightRequest="20" IsVisible="False" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Results Display -->
        <Border Grid.Row="2"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                StrokeShape="RoundRectangle 10"
                Padding="10"
                Margin="0,10,0,0">
            <ScrollView>
                <Label Text="{Binding CalculationResults}"
                       FontSize="14"
                       FontFamily="CousineRegular"
                       LineHeight="1.3"
                       FontAutoScalingEnabled="false"
                       />
            </ScrollView>
        </Border>

        <!-- Buttons Panel -->
        <HorizontalStackLayout Grid.Row="3"
                               Spacing="10"
                               Padding="10"
                               HorizontalOptions="Fill">

            <Button Text="Calculate"
                    Command="{Binding CalculateCommand}"
                    IsEnabled="{Binding IsCalculating, Converter={StaticResource InvertedBoolConverter}}"
                    HorizontalOptions="Fill" />

            <Button Text="Reset"
                    Command="{Binding ResetCommand}"
                    IsEnabled="{Binding IsCalculating, Converter={StaticResource InvertedBoolConverter}}"
                    HorizontalOptions="Fill" />
        </HorizontalStackLayout>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsCalculating}"
                           IsVisible="{Binding IsCalculating}"
                           Color="#007AFF"
                           Scale="1.5" />

    </Grid>

</ContentPage>
